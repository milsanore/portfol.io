{
  "name": "portfol-io",
  "version": "0.9.0",
  "description": "Portfolio tracking API",
  "main": "build/main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node build/main.js",
    "dev": "ts-node src/main.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "jest",
    "test:integration": "jest --config tests_integration/jest.config.js",
    "test:load": "sh tests_load/run.sh",
    "typecheck": "tsc --noEmit",
    "migrate:up": "node-pg-migrate up --migrations-dir deployment/postgres/migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir deployment/postgres/migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir deployment/postgres/migrations --migration-file-language sql",
    "import:tick-data": "ts-node --project tsconfig.scripts.json deployment/postgres/scripts/import-tick-data.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "node-pg-migrate": "^7.0.0",
    "pg": "^8.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.0.0",
    "@types/unzipper": "^0.10.0",
    "csv-parse": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "unzipper": "^0.12.0"
  }
}
