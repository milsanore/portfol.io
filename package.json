{
  "name": "portfol-io",
  "version": "0.9.0",
  "description": "Portfolio tracking API",
  "main": "build/main.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node build/main.js",
    "dev": "ts-node src/main.ts",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0"
  }
}
